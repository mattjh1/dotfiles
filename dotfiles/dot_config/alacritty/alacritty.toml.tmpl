{{ if eq .chezmoi.os "linux" -}}
[general]
import = ["~/.config/alacritty/themes/nord.toml"]
live_config_reload = true
{{- else -}}
import = ["~/.config/alacritty/themes/nord.toml"]
live_config_reload = true
{{- end }}

[bell]
animation = "EaseOutExpo"
duration = 0

{{ if eq .chezmoi.os "darwin" -}}
[colors]
draw_bold_text_with_bright_colors = true

{{ end -}}
[cursor]
style = "Block"
unfocused_hollow = false

[debug]
render_timer = false

[env]
{{ if eq .chezmoi.os "linux" -}}
TERM = "xterm-256color"
{{- else -}}
TERM = "alacritty-direct"
{{- end }}

[font]
size = 14.0

{{ if eq .chezmoi.os "linux" -}}
[font.normal]
family = "JetBrainsMono Nerd Font"
style = "Regular"

[font.bold]
family = "JetBrainsMono Nerd Font"
style = "Bold"

[font.italic]
family = "JetBrainsMono Nerd Font"
style = "Italic"

[[font.fallback]]
family = "Noto Color Emoji"
{{- else -}}
[font.bold]
family = "Hack Nerd Font Mono"
style = "Bold"

[font.glyph_offset]
x = 0
y = 0

[font.italic]
family = "Hack Nerd Font Mono"
style = "Italic"

[font.normal]
family = "Hack Nerd Font Mono"
style = "Regular"

[font.offset]
x = 0
y = 0
{{- end }}

[[hints.enabled]]
{{ if eq .chezmoi.os "linux" -}}
command = "xdg-open"
{{- else -}}
command = "open"
{{- end }}
hyperlinks = true
post_processing = true
regex = "(ipfs:|ipns:|magnet:|mailto:|gemini:|gopher:|https:|http:|news:|file:|git:|ssh:|ftp:)[^\u0000-\u001F\u007F-<>\"\\s{-}\\^⟨⟩`]+"

[hints.enabled.binding]
key = "U"
{{ if eq .chezmoi.os "linux" -}}
mods = "Control|Shift"
{{- else -}}
mods = "Command"
{{- end }}

[hints.enabled.mouse]
enabled = true
mods = "None"

