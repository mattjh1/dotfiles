[mouse]
hide_when_typing = true

[[mouse.bindings]]
action = "PasteSelection"
mouse = "Middle"

[scrolling]
history = 10000
multiplier = 3

[selection]
save_to_clipboard = true
semantic_escape_chars = ",│`|:\"' ()[]{}<>"

{{ if eq .chezmoi.os "linux" -}}
[terminal]
shell = { program = "{{ .chezmoi.homeDir }}/scripts/tmux_chooser.sh" }
{{- else -}}
[shell]
program = "{{ .chezmoi.homeDir }}/scripts/tmux_chooser.sh"
{{- end }}

[window]
decorations = "Full"
dynamic_padding = false
dynamic_title = true
opacity = 1.0
startup_mode = "Maximized"

[window.dimensions]
columns = 160
lines = 48

[window.padding]
x = 2
y = 2
